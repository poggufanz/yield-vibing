# Frontend env template — copy to frontend/.env.local (gitignored) and fill in.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# Server-side AI key (NO VITE_ prefix) — read by the /api/ai proxy, never bundled to the client.
DEEPSEEK_API_KEY=sk-your_deepseek_key

# A2A Coordination — orchestrator smart account
# Use a DEDICATED demo wallet. NEVER the user's wallet. NEVER expose in any UI render.
VITE_ORCHESTRATOR_PRIVATE_KEY=0x...
# Optional: custom Sepolia RPC for the orchestrator public client (defaults to https://rpc.sepolia.org)
VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Tavily web search — live DeFi market context injected into the Venice AI strategy prompt.
# Optional: if unset / timeout (8s), strategy generation falls back to static knowledge only.
VITE_TAVILY_API_KEY=tvly-...

# About section links (Settings → About). Optional — fall back to "#" if unset.
VITE_GITHUB_URL=https://github.com/your-org/yield-vibing
VITE_HACKQUEST_URL=https://hackquest.io/your-submission
